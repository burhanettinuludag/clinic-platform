# ============================================
# NOROSERA PRODUCTION ENVIRONMENT
# ============================================
# Bu dosyayi .env olarak kopyalayip doldurun
# cp .env.production.template .env

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=          # python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False

# Database
DB_NAME=norosera_prod
DB_USER=norosera
DB_PASSWORD=               # openssl rand -base64 32
DB_HOST=db
DB_PORT=5432

# Site
ALLOWED_HOSTS=norosera.com,www.norosera.com
CORS_ALLOWED_ORIGINS=https://norosera.com,https://www.norosera.com
FRONTEND_URL=https://norosera.com
SITE_URL=https://norosera.com

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/1

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=            # Gmail veya custom SMTP
EMAIL_HOST_PASSWORD=        # App password
DEFAULT_FROM_EMAIL=noreply@norosera.com
CONTACT_EMAIL=info@norosera.com

# reCAPTCHA v3
RECAPTCHA_SITE_KEY=         # https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_THRESHOLD=0.5

# AI / LLM
GROQ_API_KEY=               # https://console.groq.com
GEMINI_API_KEY=             # https://aistudio.google.com

# Sentry (Error Tracking)
SENTRY_DSN=                 # https://sentry.io -> Create Project -> Django
NEXT_PUBLIC_SENTRY_DSN=     # https://sentry.io -> Create Project -> Next.js

# Admin
ADMIN_URL=yonetim-paneli-7x9k/  # Rastgele admin path

# Logging
LOG_FILE=/var/log/clinic/django.log
